{
  "name": "rohit-profile",
  "version": "1.0.0",
  "description": "Personal portfolio site for Rohit Vipin Mathews — Director of Engineering & Architecture",
  "homepage": "https://rohitvipin.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohitvipin/rohit-profile"
  },
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "tsx utils/generate-sitemap.ts",
    "start": "serve out",
    "lint": "eslint . && tsx utils/lint-data.ts",
    "lint:data": "tsx utils/lint-data.ts",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "npm run build && serve out -p 3000",
    "prepare": "husky",
    "generate-favicons": "tsx utils/generate-favicons.ts",
    "fetch-avatar": "tsx utils/fetch-avatar.ts",
    "generate-resume": "tsx utils/generate-resume.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "zod": "4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "data/*.json": [
      "tsx utils/lint-data.ts"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "serve": "^14.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "~5.8",
    "vitest": "^4.1.4"
  }
}
